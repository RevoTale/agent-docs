// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/go .
{
  "name": "Documentation for the Agents",
  "image": "mcr.microsoft.com/devcontainers/go:2-1-trixie",
  "features": {},
  "remoteUser": "vscode",
  "containerEnv": {
    "CODEX_HOME": "/home/vscode/.codex"
  },
  "mounts": [
    // Mount the host Codex state directory so auth.json and refreshed tokens persist.
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
